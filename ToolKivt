WaitForKey(title := "Press any key")
{
    keyGui := Gui("+AlwaysOnTop -Caption +ToolWindow")
    keyGui.BackColor := "1E1E1E"

    keyGui.SetFont("cC95BFF s11 Bold","Segoe UI")
    keyGui.Add("Text","w260 Center",title)

    keyGui.SetFont("cDDDDDD s10","Segoe UI")
    keyGui.Add("Text","y+15 w260 Center","Key...!?")

    keyGui.SetFont("c777777 s8","Segoe UI")
    keyGui.Add("Text","y+8 w260 Center","ESC = Cancel")

    keyGui.Show("w260 h110 Center")

    Loop
    {
        Sleep(10)

        Loop 254
        {
            vk := A_Index

            if GetKeyState(Format("vk{:X}",vk),"P")
            {
                key := GetKeyName(Format("vk{:X}",vk))

                keyGui.Destroy()

                if (key = "Escape")
                    return ""

                return key
            }
        }
    }
}

ChangeKey(*)
{
    global triggerKey, SoruText, running

    oldKey := triggerKey

    try Hotkey("*" oldKey, "Off")

    newKey := ChooseValidKey()

    if (newKey = "")
    {
        if (running)
            Hotkey("*" oldKey, (*) => SpamFunc(), "On")
        return
    }

    triggerKey := newKey

    FileDelete("triggerKey.txt")
    FileAppend(triggerKey, "triggerKey.txt")

    SoruText.Text := triggerKey

    if (running)
        Hotkey("*" triggerKey, (*) => SpamFunc(), "On")
}

ChangeBoostKey(*)
{
    global BOOST_KEY, BoostKeyText

    newKey := WaitForKey("Select Boost Key")

    if (newKey = "")
        return

    try Hotkey(BOOST_KEY, "Off")

    BOOST_KEY := newKey

    BoostKeyText.Text := BOOST_KEY

    Hotkey(BOOST_KEY, TriggerBoost, "On")
}

