SpamFunc(*) {
    global running, px, py, targetColor, keyIndex, keyList, lastFire, lockoutMs, triggerKey
    cleanKey := RegExReplace(triggerKey, "^\*")
    while GetKeyState(cleanKey, "P") {
        if !running
            return

        SendInput("{r}")
        Sleep(50)

        now := A_TickCount
        if (now - lastFire < lockoutMs)
            continue

        if (PixelGetColor(px, py) != targetColor) {

    key := keyList[keyIndex]

    if (key = "x+z") {
        Send("{x}")
        Sleep 500
        Send("{z}")
    } else if (key = "c+x") {
        Send("{c}")
        Sleep 100
        Send("{x}")
    } else {
        Send("{" key "}")
    }

    lastFire := A_TickCount
}
    }
}

