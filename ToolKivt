UpdateCooldown()
{
    global CooldownText
    global lastFire
    global lockoutMs

    elapsed := A_TickCount - lastFire
    remaining := lockoutMs - elapsed

    if (remaining <= 0)
    {
        CooldownText.Text := "READY"
        return
    }

    CooldownText.Text := Round(remaining / 1000,1) " s"
}



