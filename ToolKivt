SuspendProcess(pid)
{
    hProcess := DllCall("OpenProcess", "UInt", 0x0800, "Int", 0, "UInt", pid, "Ptr")

    if hProcess
    {
        DllCall("ntdll\NtSuspendProcess", "Ptr", hProcess)
        DllCall("CloseHandle", "Ptr", hProcess)
    }
}

ResumeProcess(pid)
{
    hProcess := DllCall("OpenProcess", "UInt", 0x0800, "Int", 0, "UInt", pid, "Ptr")

    if hProcess
    {
        DllCall("ntdll\NtResumeProcess", "Ptr", hProcess)
        DllCall("CloseHandle", "Ptr", hProcess)
    }
}

PreciseSleep(ms)
{
    global g_QPCFreq

    ticks := ms * g_QPCFreq / 1000

    start := 0
    DllCall("QueryPerformanceCounter", "Int64*", &start)

    now := start

    while (now - start < ticks)
        DllCall("QueryPerformanceCounter", "Int64*", &now)
}

TriggerBoost(*)
{
    global g_BoostActive
    global Z_BOOST_ENABLED
    global PROCESS_NAME
    global Z_HOLD_TIME
    global LAG_START_DELAY
    global LAG_DURATION

    if (!Z_BOOST_ENABLED || g_BoostActive)
        return

    pid := ProcessExist(PROCESS_NAME)

    if !pid
        return

    g_BoostActive := true

    Send("{}")

    SetTimer(() => Send("{}"), -Z_HOLD_TIME)

    if (LAG_START_DELAY > 0)
        PreciseSleep(LAG_START_DELAY)

    DllCall("winmm\timeBeginPeriod", "UInt", 1)

    start := A_TickCount

    CalcTimings()
    while (A_TickCount - start < LAG_DURATION)
    {
        SuspendProcess(pid)
        PreciseSleep(FreezeTime)

        ResumeProcess(pid)
        PreciseSleep(RunTime)
    }

    DllCall("winmm\timeEndPeriod", "UInt", 1)

    ResumeProcess(pid)

    g_BoostActive := false
}
