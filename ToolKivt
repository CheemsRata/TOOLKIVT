ChooseValidKey() {
    global validKeys

    Loop {
        triggerKey := WaitForKey("Key Soru selection")

        if (triggerKey = "")
            return ""

        switch StrLower(triggerKey)
        {
            case "xbutton1":
                triggerKey := "XButton1"

            case "xbutton2":
                triggerKey := "XButton2"

            default:
                triggerKey := StrUpper(triggerKey)
        }

        for _, v in validKeys {
            if (StrUpper(v) = StrUpper(triggerKey))
                return triggerKey
        }

        MsgBox("Key not supported!", "Error", 16)
    }
}
